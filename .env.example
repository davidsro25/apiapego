# ============================
# WhaAPI - Environment Config
# ============================

# Server
PORT=3000
HOST=0.0.0.0
NODE_ENV=production

# Authentication
GLOBAL_API_KEY=your-super-secret-api-key-here

# PostgreSQL
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=whaapi
POSTGRES_PASSWORD=whaapi123
POSTGRES_DB=whaapi

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Storage for WhatsApp sessions (file | postgres)
STORAGE_TYPE=file
SESSIONS_PATH=./sessions

# Webhook
WEBHOOK_RETRY_ATTEMPTS=3
WEBHOOK_RETRY_DELAY=1000

# Rate Limit
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Meta Cloud API (opcional - para instâncias via API Oficial)
META_VERIFY_TOKEN=
META_APP_SECRET=
